#!/bin/bash
# mysql

DIR="$DIR/bin"

# Ensure we are not in a docker directory as this breaks --project-directory
# docker-compose commands!
cd "$DIR" || exit

# Ensure mysql is up
docker ps | grep -q mysql || docker compose \
  --project-directory "$DIR/../common/mysql" up -d

function="$1"
shift

args=("$@")
[ -z "${function}" ] || args=("$function" "${args[@]}")

mysql_password="${MYSQL_PASSWORD:-secret}"

case $function in
'log') . "$DIR/mysql-log" ;;
*) docker compose --project-directory "$DIR/../common/mysql" exec mysql mariadb --password="$mysql_password" "${args[@]}" ;;
esac

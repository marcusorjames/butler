#!/bin/bash
# site list subcommand — list all sites

PACKAGE="butler site list"

. "$COMMON_DIR/functions.sh"

print_usage() {
  echo "List all sites"
  echo " "
  echo "SYNOPSIS:"
  echo " "
  echo "$PACKAGE"
}

_list_one() {
  echo -e "  ${Green}$1${Color_Off}"
}

main() {
  [ "$1" = "-h" ] || [ "$1" = "--help" ] && print_usage && exit 0
  for_each_site _list_one
}

#!/bin/bash
# Docker run

PACKAGE="butler run"
SCRIPTS_DIR="$ROOT_DIR/scripts"

print_usage() {
  echo "Run a custom script"
  echo " "
  echo "SYNOPSIS:"
  echo " "
  echo "$PACKAGE script... [options]"
  echo ""
}

[ ! "$#" -gt 0 ] && print_usage && exit 1

site=$(basename "$CURRENT_SITE_DIR")

site_exists "$site" || die_with_error "Site ${CWarn}$site${Color_Off} doesn't exist"

cmd_name="$1"
site_cmd="$CURRENT_SITE_DIR/scripts/$cmd_name"
cmd="$SCRIPTS_DIR/$cmd_name"

shift

if [ -f "$site_cmd" ]; then
  # shellcheck source=/dev/null
  . "$site_cmd" "$@"
  exit 0
elif [ -f "$cmd" ]; then
  # shellcheck source=/dev/null
  . "$cmd" "$@"
  exit 0
else
  die_with_error "$site_cmd or $cmd doesn't exist"
fi

#!/bin/bash
# site convert subcommand — convert a single-project site to multi-project

PACKAGE="butler site convert"

. "$COMMON/fzfread.sh"
. "$COMMON/colours.sh"
. "$COMMON/functions.sh"
. "$COMMON/statusline.sh"

print_usage() {
  echo "Convert a single-project site to multi-project"
  echo " "
  echo "SYNOPSIS:"
  echo " "
  echo "$PACKAGE [SITE]"
  echo " "
  echo "  -h, --help         print this help"
  echo " "
  echo "Replaces the app symlink with a directory of named symlinks and"
  echo "writes BUTLER_PROJECTS to the site .env."
}

main() {
  help=false
  site="${1:-}"
  shift 2>/dev/null || true

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      help=true
      shift
      ;;
    --)
      shift
      break
      ;;
    *) break ;;
    esac
  done

  $help && print_usage && exit 0

  # Resolve site
  if [ -z "$site" ]; then
    fzf_read "$SITES_DIR" "Select a site: " site
  fi
  [ -z "$site" ] && die_with_error "No site specified"

  if ! site_dir="$(get_site_dir "$site")"; then
    die_with_error "Site ${CWarn}$site${Color_Off} doesn't exist"
  fi

  app_path="$site_dir/app"

  # Must be a plain symlink (not already a directory)
  if [ -d "$app_path" ] && [ ! -L "$app_path" ]; then
    die_with_error "Site ${CWarn}$site${Color_Off} is already a multi-project site"
  fi

  if [ ! -L "$app_path" ]; then
    die_with_error "Site ${CWarn}$site${Color_Off} has no app symlink — nothing to convert"
  fi

  current_target="$(readlink "$app_path")"
  first_proj_name="$(basename "$current_target")"

  echo -e "Converting ${Green}$site${Color_Off}: app → ${Green}$first_proj_name${Color_Off} (${current_target})"
  echo ""

  # Replace symlink with directory, re-link existing project under its name
  rm "$app_path"
  mkdir -p "$app_path"
  ln -s "$current_target" "$app_path/$first_proj_name"
  statusLine "Moved $first_proj_name into app/" "done"

  project_names="$first_proj_name"

  # Prompt for additional projects
  while true; do
    read -r -p "Add another project name (leave blank to finish): " proj_name
    [ -z "$proj_name" ] && break

    proj_dir="$(get_project_dir "$proj_name" 2>/dev/null || true)"

    if [ -n "$proj_dir" ]; then
      echo -e "Found ${Green}$proj_dir${Color_Off}"
    else
      read -r -p "Repository URL for $proj_name (leave blank to skip clone): " proj_repo
      proj_dir="$(dirname "$current_target")/$proj_name"
      mkdir -p "$proj_dir"
      [ -n "$proj_repo" ] && git clone "$proj_repo" "$proj_dir"
    fi

    ln -s "$proj_dir" "$app_path/$proj_name"
    statusLine "Linked $proj_name" "done"
    project_names="$project_names,$proj_name"
  done

  # Write BUTLER_PROJECTS to site .env
  site_env="$site_dir/.env"
  if [ -f "$site_env" ] && grep -q "^BUTLER_PROJECTS=" "$site_env"; then
    # Update existing line
    sed -i "s|^BUTLER_PROJECTS=.*|BUTLER_PROJECTS=$project_names|" "$site_env"
  else
    echo "BUTLER_PROJECTS=$project_names" >>"$site_env"
  fi
  statusLine "Wrote BUTLER_PROJECTS to site .env" "done"

  echo ""
  echo -e "${CWarn}Note:${Color_Off} Update your docker-compose.yml volume mounts —"
  echo -e "  ${Yellow}./app${Color_Off} references must now use ${Yellow}./app/$first_proj_name${Color_Off} (or whichever project)."
}


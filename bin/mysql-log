#!/bin/sh
# mysql log

cleanup() {
  butler mysql -e 'SET global general_log=off;'
  docker compose --project-directory "$ROOT_DIR/common/mysql" exec mysql rm /var/log/mysql/mysql.log
}

trap cleanup EXIT

# Ensure we are not in a docker directory as this breaks --project-directory
# docker-compose commands!
cd "$BIN_DIR" || exit

# Ensure mysql is up
docker ps | grep -q mysql || docker compose \
  --project-directory "$ROOT_DIR/common/mysql" up -d

# butler mysql -e "SET global general_log=on; SET"
butler mysql -e "SET global general_log=on;  \
  SET global general_log_file='/var/log/mysql/mysql.log'; \
  SET global log_output = 'file';"

docker compose --project-directory "$ROOT_DIR/common/mysql" exec mysql /usr/bin/tail -f /var/log/mysql/mysql.log

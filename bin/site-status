#!/bin/bash
# site status subcommand

PACKAGE="butler site status"

. "$COMMON_DIR/functions.sh"
. "$COMMON_DIR/statusline.sh"

print_usage() {
  echo "Show the status of a site or all sites"
  echo " "
  echo "SYNOPSIS:"
  echo " "
  echo "$PACKAGE NAME [OPTION]"
  echo " "
  echo "  -h, --help          print this help"
  echo "  -v, --verbose       print site directory"
}

status_single() {
  local site="$1" site_dir="$2" verbose="$3"
  local app_path="$site_dir/app"
  local status
  status="$(app_link_status "$app_path")"

  local extra=""
  $verbose && extra="[$site_dir]"

  case "$status" in
  ok) statusBadge "$site" "OK" "$CSuccess" "$extra" ;;
  broken)
    local target
    target="$(readlink "$app_path")"
    statusBadge "$site" "BROKEN" "$CError" "dead link → $target"
    echo -e "  Run ${On_White}${Black}butler site link --fix $site${Color_Off} to repair"
    ;;
  missing)
    statusBadge "$site" "MISSING" "$CError"
    echo -e "  Run ${On_White}${Black}butler site link $site${Color_Off} to link"
    ;;
  esac
}

status_multi() {
  local site="$1" site_dir="$2" verbose="$3"
  local app_path="$site_dir/app"

  local site_label="$site"
  $verbose && site_label="$site [$site_dir]"
  echo -e "$site_label"

  local p status
  for p in ${BUTLER_PROJECTS//,/ }; do
    local proj_link="$app_path/$p"
    status="$(app_link_status "$proj_link")"

    case "$status" in
    ok) statusBadge "  $p" "OK" "$CSuccess" ;;
    broken)
      local target
      target="$(readlink "$proj_link")"
      statusBadge "  $p" "BROKEN" "$CError" "dead link → $target"
      ;;
    missing) statusBadge "  $p" "MISSING" "$CError" ;;
    esac
  done
}

_status_one() {
  local site="$1" site_dir="$2"
  BUTLER_PROJECTS=""
  [ -f "$site_dir/.env" ] && {
    set -a
    . "$site_dir/.env"
    set +a
  }
  if [ -n "$BUTLER_PROJECTS" ]; then
    status_multi "$site" "$site_dir" "$verbose"
  else
    status_single "$site" "$site_dir" "$verbose"
  fi
}

main() {
  help=false
  verbose=false
  args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help) help=true ;;
    -v | --verbose) verbose=true ;;
    --)
      shift
      break
      ;;
    *) args+=("$1") ;;
    esac
    shift
  done

  set -- "${args[@]}"

  $help && print_usage && exit 0

  site="$1"

  if [ -z "$site" ]; then
    for_each_site _status_one
    exit 0
  fi

  if ! site_dir="$(get_site_dir "$site")"; then
    die_with_error "Site ${CWarn}$site${Color_Off} doesn't exist"
  fi

  _status_one "$site" "$site_dir"
}

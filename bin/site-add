#!/bin/bash
#
# site add subcommand
#
# TODO: Add ability to add local site

PACKAGE="butler site add"

. "$COMMON_DIR/fzfread.sh"
. "$COMMON_DIR/colours.sh"
. "$COMMON_DIR/functions.sh"
. "$COMMON_DIR/statusline.sh"

print_usage() {
  echo "Add a new site"
  echo " "
  echo "SYNOPSIS:"
  echo " "
  echo "$PACKAGE NAME [OPTION]"
  echo " "
  echo "  -h, --help          print this help"
  echo "  -c, --context       project context e.g. personal"
  echo "  -n, --name          name of the project (defaults to the repository name)"
  echo "  -t, --template      site template such as 'wordpress'"
  echo "  -r, --repository    git repository"
  echo "  -m, --multi         create a multi-project site"
}

add_multi() {
  local site_dir="$1" template_dir="$2"
  local -n _names="$3" _dirs="$4" _repos="$5"

  statusLine "Creating Site directory" "done"
  cp -r "$template_dir" "$site_dir/"
  mkdir -p "$site_dir/app"

  local i proj_name proj_dir proj_repo
  for i in "${!_names[@]}"; do
    proj_name="${_names[$i]}"
    proj_dir="${_dirs[$i]}"
    proj_repo="${_repos[$i]}"
    mkdir -p "$proj_dir"
    [ -n "$proj_repo" ] && git clone "$proj_repo" "$proj_dir"
    ln -s "$proj_dir" "$site_dir/app/$proj_name"
    statusLine "Linked $proj_name" "done"
  done

  local IFS=,
  write_butler_projects "$site_dir" "${_names[*]}"
  statusLine "Wrote BUTLER_PROJECTS to site .env" "done"
  statusLine "Multi-project site created" "done"
}

add_single() {
  local site_dir="$1" template_dir="$2" project_dir="$3" repository="$4"

  statusLine "Creating Site directory" "done"
  cp -r "$template_dir" "$site_dir/"

  statusLine "Creating Project directory" "done"
  mkdir -p "$project_dir"
  [ -n "$repository" ] && git clone "$repository" "$project_dir"

  statusLine "Linking Project to Site" "done"
  ln -s "$project_dir" "$site_dir/app"
}

main() {

  help=false
  multi=false
  name=''
  context=''
  repository=''
  template=''

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      help=true
      shift
      ;;
    -c | --context)
      context="$2"
      shift 2
      ;;
    -m | --multi)
      multi=true
      shift
      ;;
    -n | --name)
      name="$2"
      shift 2
      ;;
    -r | --repository)
      repository="$2"
      shift 2
      ;;
    -t | --template)
      template="$2"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    *) break ;;
    esac
  done

  $help && print_usage && exit 0

  template_root="$ROOT_DIR/templates"

  [ -z "$template" ] && fzf_read "$template_root" "Specify a template: " template
  [ -z "$template" ] && template="NULL" # Because the root dir is a directory

  if ! template_dir="$(get_template_dir "$template")"; then
    die_with_error "Template ${CWarn}$template${Color_Off} does not exist. Available: $(ls -m "$template_root/")"
  fi

  [ -z "$name" ] && read -rp "Specify a name: " name
  site_dir="$SITES_DIR/$name"
  site_exists "$name" && die_with_error "Site ${CWarn}$name${Color_Off} already exists"

  $BUTLER_REQUIRED_CONTEXT && [ -z "$context" ] && read -rp "Specify a context: " context

  [[ ! "$context" =~ ^[[:alpha:]]*$ ]] && echo -e "${CError}Context must be alphabetic" && exit 1

  if $multi; then
    # Multi-project: collect all input first, then execute
    local proj_names=() proj_dirs=() proj_repos=()
    while true; do
      read -r -p "Project name (leave blank to finish): " proj_name
      [ -z "$proj_name" ] && break

      proj_dir="$PROJECTS_DIR"
      [ -n "$context" ] && proj_dir="$proj_dir/$context"
      proj_dir="$proj_dir/$proj_name"

      if [ -d "$proj_dir" ]; then
        if [ -d "$proj_dir/.git" ]; then
          existing_repo_url=$(git -C "$proj_dir" config --get remote.origin.url)
          read -r -p "$(echo -e "Project dir $Green$proj_dir$Color_Off already exists (repo: $Green$existing_repo_url$Color_Off) — use existing? [Yn] ")" -n 1
          echo
        else
          read -r -p "$(echo -e "Project dir $Green$proj_dir$Color_Off already exists — use existing? [Yn] ")" -n 1
          echo
        fi
        [[ ! $REPLY =~ ^[Yy]$ ]] && continue
        proj_repos+=("")
      else
        read -r -p "Repository URL for $proj_name (leave blank to skip clone): " proj_repo
        if [ -n "$proj_repo" ] && ! git ls-remote "$proj_repo" >/dev/null 2>&1; then
          echo -e "${CError}Cannot reach repository $proj_repo, skipping${Color_Off}"
          continue
        fi
        proj_repos+=("$proj_repo")
      fi

      proj_names+=("$proj_name")
      proj_dirs+=("$proj_dir")
    done

    [ "${#proj_names[@]}" -gt 0 ] && add_multi "$site_dir" "$template_dir" proj_names proj_dirs proj_repos
  else
    # Single-project: app is a symlink to the project directory
    [ -z "$repository" ] && read -r -p "Specify a repository: " repository

    project_dir="$PROJECTS_DIR"
    [ -n "$context" ] && project_dir="$project_dir/$context"
    project_dir="$project_dir/$name"

    if [ -d "$project_dir" ]; then
      confirm_existing_project_dir "$project_dir" || exit 0
      statusLine "Creating Project directory" "skipped"
      statusLine "Cloning into $project_dir" "skipped"
      statusLine "Linking Project to Site" "done"
      ln -s "$project_dir" "$site_dir/app"
    else
      add_single "$site_dir" "$template_dir" "$project_dir" "$repository"
    fi
  fi

  if ! dns_is_configured; then
    local tld="${BUTLER_TLD:-test}"
    echo -e "${CWarn}Tip:${Color_Off} add ${Green}127.0.0.1 $name.$tld${Color_Off} to /etc/hosts, or run ${Green}butler dns install${Color_Off} for automatic .$tld resolution"
  fi

}


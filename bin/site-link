#!/bin/bash
# site status subcommand
# TODO: Add ability to specify directory e.g. local default should just be Sites -- configurable

PACKAGE="butler site link"
COMMON=$DIR/common

. $COMMON/functions.sh
. $COMMON/statusline.sh

print_usage() {
  echo "Link a site or all sites"
  echo " "
  echo "SYNOPSIS:"
  echo " "
  echo "$PACKAGE NAME [OPTION]"
  echo " "
  echo "  -h, --help         print this help"
  echo "  -f, --fix          auto fix any broken links"
}

check_site_exists() {
  if ! site_dir="$(get_site_dir "$1")"; then
    die_with_error "Site ${CWarn}$1${Color_Off} doesn't exist"
  fi
}

check_project_exists() {
  if ! project_path="$(get_project_dir "$1")"; then
    die_with_error "Project ${CWarn}$1${Color_Off} doesn't exist"
  fi
}

check_app_exists() {
  app_path="$SITES_DIR/$1/app"
  [ -h $app_path ] && return 0
  return 1
}

check_app_is_valid() {
  app_path="$SITES_DIR/$1/app"
  [ -e $app_path ] && return 0
  return 1
}

main() {
  help=false
  fix=false
  site="$1"
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h | --help )   help=true; shift ;;
      -f | --fix )    fix=true; shift ;;
      -- ) shift; break ;;
      * ) break ;;
    esac
  done

  $help && print_usage && exit 0

  template_root="$DIR/../templates"

  [ -z $site ] && echo -e "${CWarn}All sites is not yet implemented${Color_Off}" && exit 0

  check_site_exists $site
  check_project_exists $site

  if check_app_exists $site && check_app_is_valid $site; then
    statusBadge "$site" "SKIP" "$CWarn" "already linked"
  else
    fixed=false
    if check_app_exists $site && ! check_app_is_valid $site; then
      if $fix; then
        fixed=true
        rm $app_path
      else
        target=$(readlink "${app_path}")
        statusBadge "$site" "ERROR" "$CError" "broken link: \`${target}\`, use --fix to fix" && return 1
      fi
    fi

    if ln -s $project_path $app_path; then
      if $fixed; then
        statusBadge "$site" "FIXED" "$CWarn"
      else
        statusBadge "$site" "OK"
      fi
    else
      statusBadge "$site" "ERROR" "$CError" "failed to link site"
    fi
  fi


}

main "$@"

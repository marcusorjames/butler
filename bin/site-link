#!/bin/bash
# site link subcommand

PACKAGE="butler site link"

. "$COMMON_DIR/functions.sh"
. "$COMMON_DIR/statusline.sh"

print_usage() {
  echo "Link a site or all sites"
  echo " "
  echo "SYNOPSIS:"
  echo " "
  echo "$PACKAGE [NAME] [OPTION]"
  echo " "
  echo "  -h, --help         print this help"
  echo "  -f, --fix          auto fix any broken links"
  echo "  -v, --verbose      show skipped sites when linking all"
  echo " "
  echo "Omit NAME to process all sites."
}

link_single() {
  local site="$1" site_dir="$2" project_path="$3" fix="$4"
  local app_path="$site_dir/app"
  local status
  status="$(app_link_status "$app_path")"

  if [ "$status" = "ok" ]; then
    statusBadge "$site" "SKIP" "$CWarn" "already linked"
    return 0
  fi

  local fixed=false
  if [ "$status" = "broken" ]; then
    if $fix; then
      fixed=true
      rm "$app_path"
    else
      local target
      target=$(readlink "$app_path")
      statusBadge "$site" "ERROR" "$CError" "broken link: \`${target}\`, use --fix to fix"
      return 1
    fi
  fi

  if ln -s "$project_path" "$app_path"; then
    if $fixed; then
      statusBadge "$site" "FIXED" "$CSuccess"
    else
      statusBadge "$site" "OK"
    fi
  else
    statusBadge "$site" "ERROR" "$CError" "failed to link site"
  fi
}

link_multi() {
  local site_dir="$1" fix="$2"
  local app_path="$site_dir/app"

  if [ -L "$app_path" ]; then
    statusBadge "$site" "ERROR" "$CError" "app is a symlink — run 'butler site convert $site' first"
    return 1
  fi

  mkdir -p "$app_path"

  local p proj_path proj_link
  for p in ${BUTLER_PROJECTS//,/ }; do
    proj_link="$app_path/$p"

    if ! proj_path="$(get_project_dir "$p")"; then
      statusBadge "$p" "ERROR" "$CError" "project not found in $PROJECTS_DIR"
      continue
    fi

    local proj_status
    proj_status="$(app_link_status "$proj_link")"
    if [ "$proj_status" = "ok" ]; then
      statusBadge "$p" "SKIP" "$CWarn" "already linked"
    elif [ "$proj_status" = "broken" ]; then
      if $fix; then
        rm "$proj_link"
        ln -s "$proj_path" "$proj_link"
        statusBadge "$p" "FIXED" "$CSuccess"
      else
        local target
        target=$(readlink "$proj_link")
        statusBadge "$p" "ERROR" "$CError" "broken link: \`${target}\`, use --fix to fix"
      fi
    else
      ln -s "$proj_path" "$proj_link"
      statusBadge "$p" "OK"
    fi
  done
}

# Load site env and dispatch to link_single or link_multi.
# Returns 1 (no output) if the project directory does not exist — caller decides
# whether to error or skip silently.
link_site() {
  local site="$1" site_dir="$2" fix="$3"
  local proj_path

  BUTLER_PROJECTS=""
  if [ -f "$site_dir/site.env" ]; then
    set -a
    . "$site_dir/site.env"
    set +a
  fi
  if [ -f "$site_dir/.env" ]; then
    set -a
    . "$site_dir/.env"
    set +a
  fi

  if [ -n "$BUTLER_PROJECTS" ]; then
    link_multi "$site_dir" "$fix"
  else
    if ! proj_path="$(get_project_dir "$site")"; then
      return 1
    fi
    link_single "$site" "$site_dir" "$proj_path" "$fix"
  fi
}

_link_one() {
  if ! link_site "$1" "$2" "$fix"; then
    $verbose && statusBadge "$1" "SKIP" "$CWarn" "no project found"
  fi
}

link_all() {
  local fix="$1" verbose="$2"
  for_each_site _link_one
}

main() {
  help=false
  fix=false
  verbose=false
  local args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      help=true
      shift
      ;;
    -f | --fix)
      fix=true
      shift
      ;;
    -v | --verbose)
      verbose=true
      shift
      ;;
    --)
      shift
      break
      ;;
    *)
      args+=("$1")
      shift
      ;;
    esac
  done

  set -- "${args[@]}"
  site="${1:-}"

  $help && print_usage && exit 0

  if [ -z "$site" ]; then
    link_all "$fix" "$verbose"
    exit
  fi

  if ! site_dir="$(get_site_dir "$site")"; then
    die_with_error "Site ${CWarn}$site${Color_Off} doesn't exist"
  fi

  if ! link_site "$site" "$site_dir" "$fix"; then
    die_with_error "Project ${CWarn}$site${Color_Off} doesn't exist"
  fi
}

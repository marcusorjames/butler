#!/bin/bash
# site link subcommand

PACKAGE="butler site link"
COMMON=$DIR/common

. "$COMMON/functions.sh"
. "$COMMON/statusline.sh"

print_usage() {
  echo "Link a site or all sites"
  echo " "
  echo "SYNOPSIS:"
  echo " "
  echo "$PACKAGE NAME [OPTION]"
  echo " "
  echo "  -h, --help         print this help"
  echo "  -f, --fix          auto fix any broken links"
}

link_single() {
  local site="$1" site_dir="$2" project_path="$3" fix="$4"
  local app_path="$site_dir/app"

  if [ -L "$app_path" ] && [ -e "$app_path" ]; then
    statusBadge "$site" "SKIP" "$CWarn" "already linked"
    return 0
  fi

  local fixed=false
  if [ -L "$app_path" ] && [ ! -e "$app_path" ]; then
    if $fix; then
      fixed=true
      rm "$app_path"
    else
      local target
      target=$(readlink "$app_path")
      statusBadge "$site" "ERROR" "$CError" "broken link: \`${target}\`, use --fix to fix"
      return 1
    fi
  fi

  if ln -s "$project_path" "$app_path"; then
    if $fixed; then
      statusBadge "$site" "FIXED" "$CWarn"
    else
      statusBadge "$site" "OK"
    fi
  else
    statusBadge "$site" "ERROR" "$CError" "failed to link site"
  fi
}

link_multi() {
  local site_dir="$1" fix="$2"
  local app_path="$site_dir/app"

  if [ -L "$app_path" ]; then
    statusBadge "$site" "ERROR" "$CError" "app is a symlink — run 'butler site convert $site' first"
    return 1
  fi

  mkdir -p "$app_path"

  local p proj_path proj_link
  for p in ${BUTLER_PROJECTS//,/ }; do
    proj_link="$app_path/$p"

    if ! proj_path="$(get_project_dir "$p")"; then
      statusBadge "$p" "ERROR" "$CError" "project not found in $PROJECTS_DIR"
      continue
    fi

    if [ -L "$proj_link" ] && [ -e "$proj_link" ]; then
      statusBadge "$p" "SKIP" "$CWarn" "already linked"
    elif [ -L "$proj_link" ] && [ ! -e "$proj_link" ]; then
      if $fix; then
        rm "$proj_link"
        ln -s "$proj_path" "$proj_link"
        statusBadge "$p" "FIXED" "$CWarn"
      else
        local target
        target=$(readlink "$proj_link")
        statusBadge "$p" "ERROR" "$CError" "broken link: \`${target}\`, use --fix to fix"
      fi
    else
      ln -s "$proj_path" "$proj_link"
      statusBadge "$p" "OK"
    fi
  done
}

main() {
  help=false
  fix=false
  site="$1"
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      help=true
      shift
      ;;
    -f | --fix)
      fix=true
      shift
      ;;
    --)
      shift
      break
      ;;
    *) break ;;
    esac
  done

  $help && print_usage && exit 0

  [ -z "$site" ] && echo -e "${CWarn}All sites is not yet implemented${Color_Off}" && exit 0

  if ! site_dir="$(get_site_dir "$site")"; then
    die_with_error "Site ${CWarn}$site${Color_Off} doesn't exist"
  fi

  # Load site env to pick up BUTLER_PROJECTS if set
  BUTLER_PROJECTS=""
  if [ -f "$site_dir/.env" ]; then
    set -a
    . "$site_dir/.env"
    set +a
  fi

  if [ -n "$BUTLER_PROJECTS" ]; then
    link_multi "$site_dir" "$fix"
  else
    if ! project_path="$(get_project_dir "$site")"; then
      die_with_error "Project ${CWarn}$site${Color_Off} doesn't exist"
    fi
    link_single "$site" "$site_dir" "$project_path" "$fix"
  fi
}

main "$@"

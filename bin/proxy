#!/bin/sh
# proxy

PACKAGE="butler proxy"

print_usage() {
  echo ""
  echo "Proxy site through ngrok"
  echo "SYNOPSIS:"
  echo " "
  echo "$PACKAGE [options]"
  echo ""
  echo "NOTE:"
  echo "Ensure NGROK_AUTHTOKEN is set in .env"
}

[ "$1" = "-h" ] || [ "$1" = "--help" ] && print_usage && exit 0

docker run -it --network butler \
  -e NGROK_AUTHTOKEN="${NGROK_AUTHTOKEN}" \
  ngrok/ngrok:alpine http --host-header=rewrite "${BUTLER_PROJECT}.${BUTLER_TLD:-test}:80"

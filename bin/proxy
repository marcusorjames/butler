#!/bin/sh
# proxy

PACKAGE="butler proxy"
DIR="$DIR/bin"
COMMON=$DIR/common

. $COMMON/colours.sh

print_usage() {
  echo ""
  echo "Proxy site through ngrok"
  echo "SYNOPSIS:"
  echo " "
  echo "$PACKAGE [options]"
  echo ""
  echo "NOTE:"
  echo "Ensure NGROK_AUTHTOKEN is set in .env"
}

[ "$1" = "-h" ] || [ "$1" = "--help" ] && print_usage && exit 0

docker run -it --network nginx-proxy \
  -e NGROK_AUTHTOKEN="${NGROK_AUTHTOKEN}" \
  ngrok/ngrok:alpine http "${BUTLER_PROJECT}.${BUTLER_TLD:-test}:80"

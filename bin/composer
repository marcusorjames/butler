#!/bin/bash
# composer exec helper
# Auto-detects the project workdir from compose volume bindings and prefers
# a local composer.phar over the system composer binary if one exists.

COMMON="$DIR/bin/common"
. "$COMMON/colours.sh"

# Ensure nginx-proxy is running
[ ! "$(docker ps | grep nginx-proxy)" ] && docker compose \
  --project-directory "$DIR/common/nginx-proxy" up -d

find_volume_target() {
  awk -v src="$1" '
    /source:/ && $0 ~ src { found=1; next }
    found && /target:/     { gsub(/^[[:space:]]+target:[[:space:]]+/, ""); print; exit }
    found                  { found=0 }
  '
}

workdir=$(
  docker compose --project-directory "$CURRENT_SITE_DIR" config 2>/dev/null |
    find_volume_target "app/${BUTLER_APP_CONTAINER}"
)

workdir_args=()
[ -n "$workdir" ] && workdir_args=(-w "$workdir")

docker compose \
  --project-directory "$CURRENT_SITE_DIR" \
  exec \
  -e COMPOSER_MEMORY_LIMIT=-1 \
  "${workdir_args[@]}" \
  "$BUTLER_APP_CONTAINER" \
  sh -c 'if [ -f composer.phar ]; then php composer.phar "$@"; else composer "$@"; fi' \
  sh \
  "$@"

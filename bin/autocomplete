#!/bin/bash
# Autocomplete for butler

ROOT_DIR="$(dirname "$(readlink -f "$0")")/.."
[ -f "$ROOT_DIR/.env" ] || return 0
# shellcheck source=/dev/null
set -a
. "$ROOT_DIR/.env"
set +a

_butler_autocomplete() {
  local cur prev

  cur=${COMP_WORDS[COMP_CWORD - 1]}
  prev=${COMP_WORDS[COMP_CWORD - 2]}

  case ${COMP_CWORD} in
  1)
    COMPREPLY=()
    ;;
  2)
    case ${cur} in
    up | down | restart)
      mapfile -t COMPREPLY < <(compgen -W "$(ls "$BUTLER_SITES_DIR"/)")
      ;;
    php | exec)
      mapfile -t COMPREPLY < <(compgen -f -- "${COMP_WORDS[COMP_CWORD]}")
      ;;
    sftp)
      mapfile -t COMPREPLY < <(compgen -W "-k --key -u --upload -p --port -P --password -h --help" -- "${COMP_WORDS[COMP_CWORD]}")
      ;;
    ftp)
      mapfile -t COMPREPLY < <(compgen -W "-u --upload -p --port -P --password -h --help" -- "${COMP_WORDS[COMP_CWORD]}")
      ;;
    esac
    ;;
  3)
    case ${prev} in
    site)
      case ${cur} in
      cd)
        mapfile -t COMPREPLY < <(compgen -W "$(ls "$BUTLER_SITES_DIR"/)")
        ;;
      esac
      ;;
    sftp)
      case ${COMP_WORDS[COMP_CWORD - 1]} in
      -k | --key | -u | --upload)
        mapfile -t COMPREPLY < <(compgen -f -- "${COMP_WORDS[COMP_CWORD]}")
        ;;
      esac
      ;;
    esac
    ;;
  *)
    COMPREPLY=()
    ;;
  esac
}

complete -F _butler_autocomplete butler

#!/bin/bash
# site cd subcommand

PACKAGE="butler site cd"
ROOT_DIR=$(readlink -f "$(dirname "$(readlink -f "$0")")/../")
BIN_DIR="$ROOT_DIR/bin"
COMMON_DIR="$BIN_DIR/common"

. "$COMMON_DIR/init.sh"
. "$COMMON_DIR/functions.sh"

init

print_usage() {
  echo "Change directory into site"
  echo " "
  echo "SYNOPSIS:"
  echo " "
  echo "$PACKAGE NAME"
}

main() {
  [ ! "$#" -gt 0 ] && print_usage && exit 1

  site="$1"
  shift

  if ! site_dir="$(get_site_dir "$site")"; then
    die_with_error "Site ${CWarn}$site${Color_Off} doesn't exist"
  fi

  cd "$site_dir" || exit
  $SHELL
}

main "$@"

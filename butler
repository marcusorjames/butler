#!/bin/bash
# A dev stack builder, Install and manage your dev stack.
# Manage multiple PHP versions, automatically serve any folder

package="butler"
SOURCE="$0"
while [ -L "$SOURCE" ]; do SOURCE="$(readlink "$SOURCE")"; done
ROOT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
BIN_DIR="$ROOT_DIR/bin"
COMMON_DIR="$BIN_DIR/common"
. "$COMMON_DIR/init.sh"
. "$COMMON_DIR/colours.sh"
. "$COMMON_DIR/functions.sh"

export BUTLER_PROJECT="${BUTLER_PROJECT:-$(basename "$PWD")}"

# PATH any common binarys
export PATH="$PATH:$COMMON_DIR"

print_usage() {
  echo "butler version 0.1.0 - your friendly dev stack helper"
  echo " "
  echo "SYNOPSIS:"
  echo " "
  echo "$package COMMAND [SITE] ..."
  echo " "
  echo -e "${Blue}Commands:"
  echo " "
  echo -e "${Yellow}Site Management:"
  echo -e ""
  echo -e "${Green}site add             ${Color_Off}Add a new site"
  echo -e "${Green}site cd              ${Color_Off}Change directory to site"
  echo -e "${Green}site status          ${Color_Off}Show status of site(s)"
  echo -e "${Green}site link            ${Color_Off}Link site(s)"
  echo -e ""
  echo -e "${Yellow}Site Commands ${Color_Off}(butler COMMAND [SITE] ...):"
  echo -e ""
  echo -e "${Green}up                   ${Color_Off}Create and start container stack"
  echo -e "${Green}down                 ${Color_Off}Stop container stack"
  echo -e "${Green}restart              ${Color_Off}Restart container stack"
  echo -e "${Green}exec                 ${Color_Off}Execute command on php container"
  echo -e "${Green}php                  ${Color_Off}Execute php on container"
  echo -e "${Green}exect                ${Color_Off}Execute command on container (no TTY)"
  echo -e "${Green}shell                ${Color_Off}Start a shell session in the application container"
  echo -e "${Green}composer             ${Color_Off}Run composer on the container"
  echo -e "${Green}run                  ${Color_Off}Run a custom script"
  echo -e "${Green}proxy                ${Color_Off}Proxy site through ngrok"
  echo -e "${Green}docker-compose       ${Color_Off}Docker compose passthrough"
  echo -e ""
  echo -e "${Yellow}Other Commands:"
  echo -e ""
  echo -e "${Green}dns                  ${Color_Off}Manage automatic DNS resolution"
  echo -e "${Green}ftp                  ${Color_Off}Run ftp server"
  echo -e "${Green}sftp                 ${Color_Off}Run sftp server"
  echo -e "${Green}mysql                ${Color_Off}Run mysql shell"
}

init

[ ! "$#" -gt 0 ] && print_usage && exit 1

function="$1"
shift

HOST_UID=$(id -u)
export HOST_UID
HOST_GID=$(id -g)
export HOST_GID

# Non-site-aware commands skip site resolution; everything else resolves
case $function in
site | ftp | sftp | mysql | dns) ;;
*) resolve_site "$1" && shift ;;
esac

# Container-targeting commands resolve which container to use
case $function in
exec | php | exect | shell | composer)
  resolve_container "$1" && shift ;;
esac

case $function in
'site') . "$BIN_DIR/site" "$@" ;;

# Site commands (site resolved above)
'up') . "$BIN_DIR/docker-compose" up "$@" ;;
'down') . "$BIN_DIR/docker-compose" down "$@" ;;
'restart') . "$BIN_DIR/docker-compose" restart "$@" ;;
'exec') . "$BIN_DIR/docker-compose" exec "${BUTLER_APP_CONTAINER}" "$@" ;;
'php') . "$BIN_DIR/docker-compose" exec "${BUTLER_APP_CONTAINER}" php "$@" ;;
'exect') . "$BIN_DIR/docker-compose" exec -T "${BUTLER_APP_CONTAINER}" "$@" ;;
'shell') . "$BIN_DIR/docker-compose" exec "${BUTLER_APP_CONTAINER}" bash "$@" ;;
'composer') . "$BIN_DIR/composer" "$@" ;;
'run') . "$BIN_DIR/run" "$@" ;;
'proxy') . "$BIN_DIR/proxy" "$@" ;;
'docker-compose') . "$BIN_DIR/docker-compose" "$@" ;;

# Other
'dns') . "$BIN_DIR/dns" && main "$@" ;;
'ftp') . "$BIN_DIR/ftp" "$@" ;;
'sftp') . "$BIN_DIR/sftp" "$@" ;;
'mysql') . "$BIN_DIR/mysql" "$@" ;;

*)
  print_usage
  exit 1
  ;;
esac

# site.env — committed site defaults, loaded before .env
# Use .env for local overrides (passwords, domain overrides, TLD, etc.)

# Single-project: override the inferred project name (defaults to directory name)
# BUTLER_PROJECT=my-project

# Single-project: override the resolved project directory
# BUTLER_PROJECT_DIR=/home/<user>/Projects/my-project

# Default container name for exec/shell/composer (single-project)
BUTLER_APP_CONTAINER=php

# Multi-project: declare the projects this site manages.
# Butler will auto-export BUTLER_PROJECT_<NAME> for each, which docker-compose.yml
# can use for VIRTUAL_HOST etc. Override any domain in .env:
#   BUTLER_PROJECT_PROJECT_A=other-domain
# BUTLER_PROJECTS=project-a,project-b
